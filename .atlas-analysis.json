  "keyFeatures": [
    "Scan international phone numbers using E.164 and international formats",
    "Multiple built-in scanners: Local, Numverify, Google Search, Google CSE, OVH",
    "OSINT footprinting via Google Dorks for social media, reputation, and disposable number detection",
    "REST API and Vue.js web client for browser-based scanning",
    "Plugin system for building custom scanners in Go",
    "Usable as a Go module for programmatic integration",
    "Docker and Homebrew installation support",
    "Environment-variable-based configuration with .env file support"
  ],
  "publicApiSurface": [
    "phoneinfoga scan -n <number>",
    "phoneinfoga serve",
    "phoneinfoga scanners",
    "phoneinfoga version",
    "POST /v2/numbers",
    "GET /v2/scanners",
    "POST /v2/scanners/{scanner}/run",
    "POST /v2/scanners/{scanner}/dryrun",
    "remote.Scanner interface (Name, Description, DryRun, Run)",
    "remote.RegisterPlugin(Scanner)",
    "remote.NewLibrary(filter.Filter)",
    "number.NewNumber(string)",
    "number.IsValid(string)"
  ]
